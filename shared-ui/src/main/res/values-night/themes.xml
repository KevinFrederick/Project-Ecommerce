<resources>
    <!-- Base application theme. -->
    <style name="Theme.Ecommerce" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/blue_500</item>
        <item name="colorPrimaryVariant">@color/blue_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnBackground">@color/off_white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>

        <!-- Customize your theme here. -->
        <item name="android:textViewStyle">@style/CustomTextView</item>
        <item name="colorCustomTextInputLayout">@color/grey_700</item>
        <item name="profileIconColor">@color/grey_400</item>
        <item name="iconColor">@color/grey_400</item>
        <item name="chipColor">@color/grey_800</item>
        <item name="secondTextView">@color/grey_400</item>

        <!--BottomNavigationView-->
        <item name="colorSecondaryContainer">@color/white_10</item>
        <item name="colorOnSecondaryContainer">@color/blue_300</item>
        <item name="colorSurfaceContainer">@color/grey_1000</item>
        <item name="colorOnSurfaceVariant">@color/white_20</item>

        <!-- SnackBar -->
        <item name="colorSurfaceInverse">@color/grey_800</item>
        <item name="colorOnSurfaceInverse">@color/grey_300</item>
    </style>
</resources>