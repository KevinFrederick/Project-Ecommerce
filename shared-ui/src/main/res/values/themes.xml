<resources>
    <!-- Base application theme. -->
    <style name="Theme.Ecommerce" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/blue_500</item>
        <item name="colorPrimaryVariant">@color/blue_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnBackground">@color/grey_800</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>

        <!-- Customize your theme here. -->
        <item name="android:colorBackground">@color/off_white</item>
        <item name="android:textViewStyle">@style/CustomTextView</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="colorCustomTextInputLayout">@color/grey_100</item>
        <item name="profileIconColor">@color/black</item>
        <item name="iconColor">@color/grey_800</item>
        <item name="chipColor">@color/grey_400</item>
        <item name="secondTextView">@color/grey_600</item>

        <!-- BottomNavigationView -->
        <item name="colorSecondaryContainer">@color/blue_500_10</item>
        <item name="colorOnSecondaryContainer">@color/blue_500</item>
        <item name="colorSurfaceContainer">@color/blue_500_10</item>
        <item name="colorOnSurfaceVariant">@color/grey_500</item>

        <!-- SnackBar -->
        <item name="colorSurfaceInverse">@color/grey_300</item>
        <item name="colorOnSurfaceInverse">@color/grey_800</item>
    </style>

    <style name="CustomTextView" parent="android:Widget.TextView">
        <item name="android:textColor">?attr/colorOnBackground</item>
    </style>

    <style name="CustomRangeSliderStyle" parent="Widget.Material3.Slider">
        <item name="trackColorActive">?attr/colorPrimary</item>
        <item name="trackHeight">8dp</item>
        <item name="tickVisible">false</item>
    </style>

</resources>