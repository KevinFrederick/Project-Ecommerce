<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="CustomTextInput">
        <attr name="android:enabled" />
        <attr name="android:imeOptions"/>
        <attr name="custom_start_icon" format="reference" />
        <attr name="custom_hint" format="string" />
        <attr name="custom_placeholder" format="string" />
        <attr name="android:inputType" />
        <attr name="custom_endIconMode" >
            <enum name="none" value="0"/>
            <enum name="password_toggle" value="1"/>
            <enum name="clear_text" value="2"/>
            <enum name="dropdown_menu" value="3"/>
            <enum name="custom" value="-1"/>
        </attr>
    </declare-styleable>

    <!-- Theme -->
    <attr name="colorCustomTextInputLayout" format="color|reference"/>
    <attr name="profileIconColor" format="color|reference" />
    <attr name="iconColor" format="color|reference"/>
    <attr name="chipColor" format="color|reference"/>
    <attr name="secondTextView" format="color|reference"/>
</resources>