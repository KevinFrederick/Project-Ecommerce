<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_transaction"
    app:startDestination="@id/fragmentTransaction">

    <fragment
        android:id="@+id/fragmentTransaction"
        android:name="com.kevinfreyap.transaction.ui.TransactionFragment"
        android:label="@string/title_transactions"
        tools:layout="@layout/fragment_transaction" >

        <deepLink
            android:id="@+id/deep_link_transaction"
            app:uri="app://ecommerce/transaction"/>

    </fragment>

    <fragment
        android:id="@+id/transactionDetailFragment"
        android:name="com.kevinfreyap.transaction.ui.TransactionDetailFragment"
        android:label="@string/title_transaction_detail"
        tools:layout="@layout/fragment_transaction_detail" >

        <deepLink
            android:id="@+id/deep_link_transaction_detail"
            app:uri="app://ecommerce/transaction/{transactionId}"/>

        <argument
            android:name="transactionId"
            app:argType="string"/>

    </fragment>
</navigation>