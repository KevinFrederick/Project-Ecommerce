<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.CheckoutFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/summary_divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp"
            android:clipToPadding="false">

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progress_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="0dp"
                android:indeterminate="true"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <androidx.cardview.widget.CardView
                android:id="@+id/card_shipping_address"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:layout_constraintTop_toBottomOf="@id/progress_bar"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp">

                    <TextView
                        android:id="@+id/tv_shipping_address_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/title_shipping_address"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium.Emphasized"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <ImageView
                        android:id="@+id/iv_location_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:src="@drawable/ic_location_on_24"
                        android:contentDescription="@string/image_location"
                        app:layout_constraintTop_toBottomOf="@id/tv_shipping_address_label"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/tv_shipping_address"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        app:layout_constraintTop_toTopOf="@id/iv_location_icon"
                        app:layout_constraintBottom_toBottomOf="@id/iv_location_icon"
                        app:layout_constraintStart_toEndOf="@id/iv_location_icon"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tv_payment_method_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/title_payment_methods"
                android:textAppearance="@style/TextAppearance.Material3.TitleLarge.Emphasized"
                app:layout_constraintTop_toBottomOf="@id/card_shipping_address"
                app:layout_constraintStart_toStartOf="parent" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cod_option"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/background_payment_option"
                app:layout_constraintTop_toBottomOf="@id/tv_payment_method_label">

                <ImageView
                    android:id="@+id/iv_cod_selector"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/image_cod_payment"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:src="@drawable/ic_radio_button_checked_24" />

                <TextView
                    android:id="@+id/tv_cod_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:text="@string/delivery_payment"
                    android:textAppearance="@style/TextAppearance.Material3.BodyLarge.Emphasized"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/iv_cod_selector"
                    app:layout_constraintEnd_toStartOf="@id/iv_cod_icon" />

                <ImageView
                    android:id="@+id/iv_cod_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_cod_24"
                    android:contentDescription="@string/image_cod_payment"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/tv_cod_label"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/card_option"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/background_payment_option"
                android:clickable="false"
                android:alpha="0.4"
                app:layout_constraintTop_toBottomOf="@id/cod_option">

                <ImageView
                    android:id="@+id/iv_card_selector"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/image_card_payment"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:src="@drawable/ic_radio_button_unchecked_24" />

                <TextView
                    android:id="@+id/tv_card_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:text="@string/card_payment"
                    android:textAppearance="@style/TextAppearance.Material3.BodyLarge.Emphasized"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/tv_not_available"
                    app:layout_constraintStart_toEndOf="@id/iv_card_selector"
                    app:layout_constraintEnd_toStartOf="@id/iv_card_icon" />

                <TextView
                    android:id="@+id/tv_not_available"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/error_not_available"
                    app:layout_constraintTop_toBottomOf="@id/tv_card_label"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="@id/tv_card_label"
                    app:layout_constraintEnd_toEndOf="@id/tv_card_label" />

                <ImageView
                    android:id="@+id/iv_card_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_credit_card_24"
                    android:contentDescription="@string/image_card_payment"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/tv_card_label"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/tv_voucher_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/title_voucher"
                android:textAppearance="@style/TextAppearance.Material3.TitleLarge.Emphasized"
                app:layout_constraintTop_toBottomOf="@id/card_option"
                app:layout_constraintStart_toStartOf="parent" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/voucher_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:padding="16dp"
                android:background="@drawable/background_payment_option"
                app:layout_constraintTop_toBottomOf="@id/tv_voucher_label">

                <ImageView
                    android:id="@+id/iv_voucher_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_coupon_24"
                    android:contentDescription="@string/image_voucher"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <EditText
                    android:id="@+id/et_voucher_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp"
                    android:background="@null"
                    android:hint="@string/enter_voucher"
                    android:maxLines="1"
                    android:inputType="text"
                    app:layout_constraintHorizontal_weight="5"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/iv_voucher_icon"
                    app:layout_constraintEnd_toStartOf="@id/tv_apply_btn" />

                <TextView
                    android:id="@+id/tv_apply_btn"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:gravity="center"
                    android:text="@string/apply"
                    android:textAppearance="@style/TextAppearance.Material3.BodyLarge.Emphasized"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/et_voucher_input"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/tv_order_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/title_order_summary"
                android:textAppearance="@style/TextAppearance.Material3.TitleLarge.Emphasized"
                app:layout_constraintTop_toBottomOf="@id/voucher_container"
                app:layout_constraintStart_toStartOf="parent" />

            <com.yanzhenjie.recyclerview.SwipeRecyclerView
                android:id="@+id/rv_cart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                app:layout_constraintTop_toBottomOf="@id/tv_order_summary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:listitem="@layout/item_cart"
                tools:itemCount="3"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <View
        android:id="@+id/summary_divider"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:layout_marginBottom="24dp"
        android:background="@color/grey_500"
        app:layout_constraintVertical_bias="1"
        app:layout_constraintBottom_toTopOf="@id/tv_subtotal_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_subtotal_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:layout_marginStart="16dp"
        android:text="@string/subtotal"
        android:textColor="?attr/secondTextView"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        app:layout_constraintBottom_toTopOf="@id/tv_shipping_label"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_subtotal_price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
        app:layout_constraintTop_toTopOf="@id/tv_subtotal_label"
        app:layout_constraintBottom_toBottomOf="@id/tv_subtotal_label"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="$60" />

    <TextView
        android:id="@+id/tv_shipping_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:layout_marginStart="16dp"
        android:text="@string/shipping_fee"
        android:textColor="?attr/secondTextView"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        app:layout_constraintBottom_toTopOf="@id/tv_voucher_discount_label"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_shipping_fee"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
        app:layout_constraintTop_toTopOf="@id/tv_shipping_label"
        app:layout_constraintBottom_toBottomOf="@id/tv_shipping_label"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="$20" />

    <TextView
        android:id="@+id/tv_voucher_discount_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:layout_marginStart="16dp"
        android:text="@string/voucher"
        android:textColor="?attr/secondTextView"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        app:layout_constraintBottom_toTopOf="@id/tv_total_label"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_voucher_discount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
        app:layout_constraintTop_toTopOf="@id/tv_voucher_discount_label"
        app:layout_constraintBottom_toBottomOf="@id/tv_voucher_discount_label"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="- $20" />

    <TextView
        android:id="@+id/tv_total_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:layout_marginStart="16dp"
        android:text="@string/total"
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge.Emphasized"
        app:layout_constraintBottom_toTopOf="@id/btn_order"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_total_price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:textAppearance="@style/TextAppearance.Material3.TitleLarge.Emphasized"
        app:layout_constraintTop_toTopOf="@id/tv_total_label"
        app:layout_constraintBottom_toBottomOf="@id/tv_total_label"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="$80" />

    <Button
        android:id="@+id/btn_order"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingVertical="12dp"
        android:layout_marginBottom="32dp"
        android:layout_marginHorizontal="16dp"
        android:text="@string/order"
        android:textAppearance="@style/TextAppearance.Material3.TitleLarge.Emphasized"
        android:enabled="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>